{% layout 'theme' %}
{% block head %}
{{ 'listing.css' | asset_url | stylesheet_tag }}
{% endblock %}
{% block content %}
{% if category %}
	{% render 'breadcrumbs', aria_label: 'Breadcrumb', level_1_href: '/', level_1_label: 'Inicio', level_2_href: '/categorias', level_2_label: 'Categorías', current_label: category.name %}
{% else %}
	{% render 'breadcrumbs', aria_label: 'Breadcrumb', level_1_href: '/', level_1_label: 'Inicio', current_label: 'Productos' %}
{% endif %}

{% if category %}
	{% assign products_origin_url = category.publicUrl | default: request.path %}
	{% if products_origin_url contains request.host %}
		{% assign products_origin_url = products_origin_url | split: request.host | last %}
	{% endif %}
	{% products limit: products_page_size, page: current_page, category_id: category.id, include_products_from_subcategories: true %}
	<section class="listing-head" aria-labelledby="category-title">
		<div class="listing-meta">
			<h1 id="category-title" class="page-title">{{ category.name }}</h1>
			{% if category.description != blank %}
			<p id="category-description" class="category-description">{{ category.description }}</p>
			{% endif %}
		</div>
		<div class="listing-subhead">
			<p id="category-products-summary" class="category-products-summary">{{ paginate.items }} {% if paginate.items == 1 %}producto{% else %}productos{% endif %}</p>
		</div>
	</section>
	{% if products.size > 0 %}
	<div
		id="product-listing"
		data-fragment-url="/__fragments/products"
		data-page="{{ paginate.current_page }}"
		data-page-size="{{ paginate.page_size }}"
		data-category-id="{{ category.id }}"
		data-category-title="{{ category.name | escape_attr }}"
		data-origin-url="{{ products_origin_url | escape_attr }}"
		data-origin-title="{{ category.name | escape_attr }}"
		data-include-subcategories="true"
		{% if paginate.next %}data-next-page="{{ paginate.next.page }}"{% endif %}
	>
		<div id="product-grid" class="product-list">
			{% for product in products %}
				{% render 'product-item', product: product, origin_url: products_origin_url, origin_title: category.name %}
			{% endfor %}
		</div>
		{% if paginate.next %}
		<div style="display:flex;justify-content:center;margin-top:var(--space-8);">
			<button type="button" id="load-more-btn" class="btn btn--secondary">Cargar más productos</button>
		</div>
		{% endif %}
	</div>
	{% else %}
	<div class="empty-state">
		{% render 'icon-package-search', size: 48 %}
		<span class="empty-state__title">No hay productos en esta categoría</span>
	</div>
	{% endif %}
	{% endproducts %}
{% else %}
	{% assign products_origin_url = '/productos' %}
	{% if search_query != blank %}
		{% assign encoded_search_query = search_query | url_encode %}
		{% assign products_origin_url = '/productos?q=' | append: encoded_search_query %}
	{% endif %}
	{% products limit: products_page_size, page: current_page, search: search_query, sort: 'sales', order: 'desc' %}
	<section class="listing-head{% if search_query %} listing-head--search{% endif %}" aria-labelledby="products-page-title">
		<div class="listing-meta">
			<h1 id="products-page-title" class="page-title">Productos</h1>
		</div>
		<div class="listing-subhead">
			<div class="listing-results-meta">
				<p id="products-results-summary">
					{% if search_query %}
						{{ paginate.items }} {% if paginate.items == 1 %}resultado{% else %}resultados{% endif %} para "{{ search_query | escape }}"
					{% else %}
						{{ paginate.items }} {% if paginate.items == 1 %}producto{% else %}productos{% endif %}
					{% endif %}
				</p>
				<a
					id="products-clear-search"
					class="listing-clear-search"
					href="/productos"
					aria-label="Limpiar búsqueda"
					title="Limpiar búsqueda"
					{% unless search_query %}hidden{% endunless %}
				>
					{% render 'icon-x', size: 16 %}
				</a>
			</div>
		</div>
	</section>
	{% if products.size > 0 %}
	<div
		id="product-listing"
		data-fragment-url="/__fragments/products"
		data-page="{{ paginate.current_page }}"
		data-page-size="{{ paginate.page_size }}"
		data-origin-url="{{ products_origin_url | escape_attr }}"
		data-origin-title="Productos"
		{% if search_query %}data-search-query="{{ search_query | escape_attr }}"{% endif %}
		data-criteria="sales"
		data-order="desc"
		{% if paginate.next %}data-next-page="{{ paginate.next.page }}"{% endif %}
	>
		<div id="product-grid" class="product-list">
			{% for product in products %}
				{% render 'product-item', product: product, origin_url: products_origin_url, origin_title: 'Productos' %}
			{% endfor %}
		</div>
		{% if paginate.next %}
		<div style="display:flex;justify-content:center;margin-top:var(--space-8);">
			<button type="button" id="load-more-btn" class="btn btn--secondary">Cargar más productos</button>
		</div>
		{% endif %}
	</div>
	{% else %}
	<div class="empty-state">
		{% render 'icon-package-search', size: 48 %}
		<span class="empty-state__title">{% if search_query %}No encontramos productos para "{{ search_query | escape }}"{% else %}No hay productos publicados aún{% endif %}</span>
	</div>
	{% endif %}
	{% endproducts %}
{% endif %}

<script type="module">
import '/assets/listing-quick-add.js'

const initLoadMore = () => {
	const listing = document.getElementById('product-listing')
	const grid = document.getElementById('product-grid')
	const btn = document.getElementById('load-more-btn')
	if (!listing || !grid) return

	const fragmentUrl = listing.dataset.fragmentUrl
	const pageSize = listing.dataset.pageSize
	const searchQuery = listing.dataset.searchQuery || ''
	const criteria = listing.dataset.criteria || ''
	const order = listing.dataset.order || ''
	const categoryId = listing.dataset.categoryId || ''
	const originUrl = listing.dataset.originUrl || ''
	const originTitle = listing.dataset.originTitle || ''
	const includeSubcategories = listing.dataset.includeSubcategories || ''

	let nextPage = listing.dataset.nextPage ? Number(listing.dataset.nextPage) : null
	let loading = false

	if (!btn) return

	btn.addEventListener('click', async () => {
		if (loading || nextPage == null) return
		loading = true
		btn.textContent = 'Cargando...'
		btn.disabled = true

		try {
			const params = new URLSearchParams({ page: String(nextPage), size: pageSize })
			if (searchQuery) params.set('q', searchQuery)
			if (criteria) params.set('criteria', criteria)
			if (order) params.set('order', order)
			if (categoryId) params.set('categoryId', categoryId)
			if (originUrl) params.set('originUrl', originUrl)
			if (originTitle) params.set('originTitle', originTitle)
			if (includeSubcategories) params.set('includeProductsFromSubcategories', includeSubcategories)

			const res = await fetch(`${fragmentUrl}?${params.toString()}`)
			if (!res.ok) throw new Error('fetch failed')

			const html = await res.text()
			const tmp = document.createElement('div')
			tmp.innerHTML = html

			const fragment = tmp.querySelector('[data-products-fragment]')
			if (fragment) {
				for (const child of fragment.children) {
					grid.appendChild(child.cloneNode(true))
				}
				const hasMore = fragment.dataset.hasMore === 'true'
				nextPage = hasMore && fragment.dataset.nextPage ? Number(fragment.dataset.nextPage) : null
			} else {
				nextPage = null
			}

		} catch {
			// silently fail
		} finally {
			loading = false
			if (nextPage == null) {
				btn.remove()
			} else {
				btn.textContent = 'Cargar más productos'
				btn.disabled = false
			}
		}
	})
}

initLoadMore()
</script>
{% endblock %}
