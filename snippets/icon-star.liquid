{%- comment -%}
  Lucide icon: star
  Usage:
    {% render 'icon-star' %}
    {% render 'icon-star', size: 32 %}
    {% render 'icon-star', class: 'custom-class' %}
    {% render 'icon-star', stroke_width: 1.5 %}
{%- endcomment -%}
{%- liquid
  assign size = size | default: 24
  assign stroke_width = stroke_width | default: 2
-%}
<svg
  xmlns="http://www.w3.org/2000/svg"
  width="{{ size }}"
  height="{{ size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="{{ stroke_width }}"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="lucide lucide-star{% if class %} {{ class }}{% endif %}"
  aria-hidden="true"
>
