  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="{{ stroke_width }}"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="lucide lucide-file-warning{% if class %} {{ class }}{% endif %}"
  aria-hidden="true"
>
