{%- comment -%}
  Lucide icon: instagram
  Usage:
    {% render 'icon-instagram' %}
    {% render 'icon-instagram', size: 32 %}
    {% render 'icon-instagram', class: 'custom-class' %}
    {% render 'icon-instagram', stroke_width: 1.5 %}
{%- endcomment -%}
{%- liquid
  assign size = size | default: 24
  assign stroke_width = stroke_width | default: 2
-%}
<svg
  xmlns="http://www.w3.org/2000/svg"
  width="{{ size }}"
  height="{{ size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="{{ stroke_width }}"
  stroke-linecap="round"
  stroke-linejoin="round"
  class="lucide lucide-instagram{% if class %} {{ class }}{% endif %}"
  aria-hidden="true"
>
<rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
  <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
</svg>
