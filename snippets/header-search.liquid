<div class="storefront-search" data-storefront-search>
	<div class="storefront-search-shell">
		<button class="storefront-search__mobile-trigger" type="button" aria-label="Abrir búsqueda" data-search-open>
			{% render 'icon-search', size: 18 %}
		</button>
		<button class="storefront-search__mobile-backdrop" type="button" aria-label="Cerrar búsqueda" data-search-backdrop></button>
		<form class="storefront-search__form" action="/productos" method="get" role="search" autocomplete="off">
			<label class="sr-only" for="storefront-search-input">Buscar productos</label>
			<div class="storefront-search__control inline-form-control">
				<span class="storefront-search__icon" data-search-icon aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-form-control__icon"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
				</span>
				<input
					id="storefront-search-input"
					type="search"
					name="q"
					placeholder="Buscar..."
					class="inline-form-control__input"
					value=""
				/>
				<button class="storefront-search__submit inline-form-control__button" type="submit">Buscar</button>
				<button class="storefront-search__mobile-close" type="button" aria-label="Limpiar y cerrar búsqueda" data-search-close>
					{% render 'icon-x', size: 16 %}
				</button>
			</div>
			<div class="storefront-search__dropdown" data-search-dropdown hidden></div>
		</form>
	</div>
</div>
